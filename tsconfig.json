{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "build/",
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "types": ["node", "homey"]
  },
  "include": ["lib/**/*.ts", "app.ts", "drivers/**/*.ts"],
  "exclude": ["node_modules", "build"]
}
